# Copy to .env and fill in. .env is gitignored.

# Read-only warehouse connection (required).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Base URL for a customer's ServiceTitan profile in exports. {id} is the customer_id.
ST_CUSTOMER_URL=https://go.servicetitan.com/#/customer/{id}

# ---- Ad platforms (PROTOTYPE) -------------------------------------------------
# Dry-run is the default: audiences are hashed and logged, never uploaded. Set to
# "false" only once the real SDK calls in app/ads.py are uncommented and creds below
# are filled (load these from Secret Manager in production, not a checked-in file).
ADS_DRY_RUN=true

# Google Ads (Customer Match)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_MATCH_LIST_ID=

# Meta Ads (Custom Audiences)
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_CUSTOM_AUDIENCE_ID=
