# Copy to .env.local and fill in. .env*.local is gitignored.

# ---- Read-only warehouse connection (required) --------------------------------
# Option A — TCP (local dev, direct connection):
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Option B — Cloud SQL via unix socket (Cloud Run). Set this instead of (or in
# addition to) a TCP DATABASE_URL and lib/db.ts connects via /cloudsql/<conn>.
# INSTANCE_CONNECTION_NAME=project:region:instance
# When using the socket, supply the rest of the connection out-of-band:
# PGDATABASE=dbname
# PGUSER=user
# PGPASSWORD=password

# Base URL for a customer's ServiceTitan profile in exports. {id} is the customer_id.
ST_CUSTOMER_URL=https://go.servicetitan.com/#/customer/{id}

# ---- Ad platforms (PROTOTYPE) -------------------------------------------------
# Dry-run is the default: audiences are hashed and logged, never uploaded. Set to
# "false" only once real SDK calls exist and creds below are filled (load these from
# Secret Manager in production, not a checked-in file).
ADS_DRY_RUN=true

# Google Ads (Customer Match)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_MATCH_LIST_ID=

# Meta Ads (Custom Audiences)
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_CUSTOM_AUDIENCE_ID=
